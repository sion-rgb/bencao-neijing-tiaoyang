{
  "name": "bencao-neijing-tiaoyang",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "validate:data": "tsx scripts/validate-data.ts",
    "validate:knowledge": "tsx tools/knowledge/validate-knowledge.ts",
    "audit:scoring": "tsx scripts/audit-scoring.ts",
