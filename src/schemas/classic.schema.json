{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "classic.schema.json",
  "title": "ClassicEntry",
  "type": "object",
  "required": ["id", "book", "section", "originalText", "modernSummary", "tags", "sourceStatus", "sourceUrl", "reviewStatus"],
  "properties": {
    "id": { "type": "string", "minLength": 1 }, "book": { "enum": ["黃帝內經", "本草綱目"] }, "section": { "type": "string", "minLength": 1 }, "chapter": { "type": "string" }, "originalText": { "type": "string", "minLength": 1 }, "modernSummary": { "type": "string", "minLength": 1 }, "tags": { "type": "array", "items": { "type": "string" } }, "sourceStatus": { "enum": ["verified", "needs-review"] }, "sourceUrl": { "type": "string", "pattern": "^https://" }, "reviewStatus": { "enum": ["draft", "tcm-reviewed", "safety-reviewed", "approved"] }
  },
  "additionalProperties": false
}
