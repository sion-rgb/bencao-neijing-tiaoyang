{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "question.schema.json",
  "title": "ConstitutionQuestion",
  "type": "object",
  "required": ["id", "category", "prompt", "required", "options", "reviewStatus"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "category": { "enum": ["body", "energy", "sweat", "digestion", "sleep", "headSkinLimbs", "tongue"] },
    "prompt": { "type": "string", "minLength": 1 },
    "helpText": { "type": "string" },
    "required": { "type": "boolean" },
    "multiple": { "type": "boolean" },
    "reviewStatus": { "enum": ["draft", "tcm-reviewed", "safety-reviewed", "approved"] },
    "options": {
      "type": "array", "minItems": 2,
      "items": {
        "type": "object",
        "required": ["optionId", "label", "patternWeights", "safetyFlags", "explanationTags"],
        "properties": {
          "optionId": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "patternWeights": { "type": "object", "additionalProperties": { "type": "number", "minimum": 0 } },
          "safetyFlags": { "type": "array", "items": { "type": "string" } },
          "explanationTags": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
