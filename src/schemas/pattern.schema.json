{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pattern.schema.json",
  "title": "Pattern",
  "type": "object",
  "required": ["id", "name", "shortName", "principle", "priorities", "habits", "foodDirections", "avoid", "classicIds", "reviewStatus"],
  "properties": {
    "id": { "type": "string", "minLength": 1 }, "name": { "type": "string", "minLength": 1 }, "shortName": { "type": "string", "minLength": 1 }, "principle": { "type": "string", "minLength": 1 },
    "priorities": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "habits": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "foodDirections": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "avoid": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "classicIds": { "type": "array", "items": { "type": "string" } },
    "reviewStatus": { "enum": ["draft", "tcm-reviewed", "safety-reviewed", "approved"] }
  },
  "additionalProperties": false
}
